{
  "name": "ds",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:ds": "node scripts/lint-ds.mjs",
    "lint:ds:values": "node scripts/lint-ds-values.mjs",
    "lint:ds:invariants": "node scripts/lint-ds-invariants.mjs",
    "lint:ds:contracts": "node scripts/lint-ds-contracts.mjs",
    "lint:ds:keyboard": "node scripts/lint-ds-keyboard.mjs",
    "lint:ds:shell": "node scripts/lint-ds-shell.mjs",
    "lint:ds:flat-layout": "node scripts/lint-flat-layout.mjs",
    "lint:ds:slots": "node scripts/lint-slot-invariants.mjs",
    "lint:ds:data-part": "node scripts/lint-ds-data-part.mjs",
    "lint:ds:all": "pnpm lint:ds && pnpm lint:ds:values && pnpm lint:ds:invariants && pnpm lint:ds:contracts && pnpm lint:ds:keyboard && pnpm lint:ds:shell && pnpm lint:ds:flat-layout && pnpm lint:ds:slots && pnpm lint:ds:data-part",
    "lint:dead": "node scripts/lint-dead.mjs",
    "audit:role-css": "tsx scripts/role-css-audit.ts",
    "audit:ds-css": "tsx scripts/audit-ds-css.ts",
    "audit:css-decls": "tsx scripts/audit-css-decls.ts",
    "converge:css": "tsx scripts/converge-css.ts",
    "audit:hmi": "node scripts/audit-hmi.mjs",
    "aria:xray": "node scripts/aria-xray.mjs",
    "aria:tree": "TSX_TSCONFIG_PATH=tsconfig.app.json node --import tsx --loader ./scripts/aria-tree-loader.mjs scripts/aria-tree.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@oddbird/popover-polyfill": "^0.6.1",
    "@tanstack/react-router": "^1.168.23",
    "lucide-static": "^1.9.0",
    "marked": "^18.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-frame-component": "^5.3.2",
    "shiki": "^4.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/router-plugin": "^1.167.26",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "puppeteer-core": "^24.42.0",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
