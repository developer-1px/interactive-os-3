{
  "name": "headless",
  "private": true,
  "version": "0.0.0",
  "description": "@p/headless workspace with Tailwind-based app showcases (slides, finder, markdown).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docs:api": "cd packages/headless && npx typedoc --json ../../docs/api.json --out ../../docs/api",
    "docs:llms": "pnpm docs:api && node scripts/gen-llms-txt.mjs"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@oddbird/popover-polyfill": "^0.6.1",
    "@tanstack/react-router": "^1.168.23",
    "lucide-static": "^1.9.0",
    "marked": "^18.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-frame-component": "^5.3.2",
    "shiki": "^4.0.2",
    "zod": "^4.3.6",
    "zod-crud": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/router-plugin": "^1.167.26",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.13",
    "puppeteer-core": "^24.42.0",
    "tailwindcss": "^3.4.19",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
