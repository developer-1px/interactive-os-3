{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/index.ts",
    "src/patterns/index.ts",
    "src/axes/index.ts",
    "src/store/index.ts",
    "src/gesture/index.ts",
    "src/key/index.ts",
    "src/local/index.ts",
    "src/roving/index.ts",
    "src/state/index.ts"
  ],
  "out": "docs/api",
  "readme": "README.md",
  "includeVersion": true,
  "excludeInternal": true,
  "excludePrivate": true,
  "categorizeByGroup": true,
  "navigationLinks": {
    "GitHub": "https://github.com/"
  },
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": false
  }
}
