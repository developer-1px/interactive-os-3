{
  "name": "@p/headless",
  "version": "0.0.1",
  "description": "ARIA 행동 인프라 — axis 합성, roving tabindex, gesture/intent 변환, FlatLayout 선언적 트리, Resource 단일 데이터 인터페이스. 토큰/CSS/UI 어휘 0건.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./patterns": {
      "types": "./dist/patterns/index.d.ts",
      "import": "./dist/patterns/index.js",
      "require": "./dist/patterns/index.cjs"
    },
    "./axes": {
      "types": "./dist/axes/index.d.ts",
      "import": "./dist/axes/index.js",
      "require": "./dist/axes/index.cjs"
    },
    "./feature": {
      "types": "./dist/feature/index.d.ts",
      "import": "./dist/feature/index.js",
      "require": "./dist/feature/index.cjs"
    },
    "./gesture": {
      "types": "./dist/gesture/index.d.ts",
      "import": "./dist/gesture/index.js",
      "require": "./dist/gesture/index.cjs"
    },
    "./key": {
      "types": "./dist/key/index.d.ts",
      "import": "./dist/key/index.js",
      "require": "./dist/key/index.cjs"
    },
    "./local": {
      "types": "./dist/local/index.d.ts",
      "import": "./dist/local/index.js",
      "require": "./dist/local/index.cjs"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js",
      "require": "./dist/layout/index.cjs"
    },
    "./roving": {
      "types": "./dist/roving/index.d.ts",
      "import": "./dist/roving/index.js",
      "require": "./dist/roving/index.cjs"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js",
      "require": "./dist/state/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    },
    "./*/": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.cjs"
    }
  },
  "files": [
    "dist",
    "INVARIANTS.md",
    "PATTERNS.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
