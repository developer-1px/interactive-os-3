{
  "name": "@p/headless",
  "version": "0.0.2",
  "description": "ARIA 행동 인프라 — axis 합성, roving tabindex, gesture/intent 변환, ARIA 패턴. 옵션 store 어댑터(/store), 데모 quick-start(/local). 토큰/CSS/UI 어휘 0건.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./patterns": {
      "types": "./dist/patterns/index.d.ts",
      "import": "./dist/patterns/index.js",
      "require": "./dist/patterns/index.cjs"
    },
    "./axes": {
      "types": "./dist/axes/index.d.ts",
      "import": "./dist/axes/index.js",
      "require": "./dist/axes/index.cjs"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.js",
      "require": "./dist/store/index.cjs"
    },
    "./gesture": {
      "types": "./dist/gesture/index.d.ts",
      "import": "./dist/gesture/index.js",
      "require": "./dist/gesture/index.cjs"
    },
    "./key": {
      "types": "./dist/key/index.d.ts",
      "import": "./dist/key/index.js",
      "require": "./dist/key/index.cjs"
    },
    "./local": {
      "types": "./dist/local/index.d.ts",
      "import": "./dist/local/index.js",
      "require": "./dist/local/index.cjs"
    },
    "./roving": {
      "types": "./dist/roving/index.d.ts",
      "import": "./dist/roving/index.js",
      "require": "./dist/roving/index.cjs"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js",
      "require": "./dist/state/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    },
    "./*/": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.cjs"
    }
  },
  "files": [
    "dist",
    "INVARIANTS.md",
    "PATTERNS.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "clean": "rm -rf dist docs/api"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
