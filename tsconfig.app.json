{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@p/ds": ["packages/ds/src/index.ts"],
      "@p/ds/*": ["packages/ds/src/*"],
      "@p/fs": ["packages/fs/src/index.ts"],
      "@p/fs/*": ["packages/fs/src/*"],
      "@p/devtools": ["packages/devtools/src/index.ts"],
      "@p/devtools/*": ["packages/devtools/src/*"],
      "@p/app": ["packages/app/src/main.tsx"],
      "@p/app/*": ["packages/app/src/*"],
      "@apps/*": ["apps/*/src"],
      "@showcase/playground": ["showcase/playground/src/index.ts"],
      "@showcase/playground/*": ["showcase/playground/src/*"],
      "@showcase/canvas": ["showcase/canvas/src/index.ts"],
      "@showcase/canvas/*": ["showcase/canvas/src/*"],
      "@showcase/catalog": ["showcase/catalog/src/index.ts"],
      "@showcase/catalog/*": ["showcase/catalog/src/*"],
      "@showcase/foundations": ["showcase/foundations/src/index.ts"],
      "@showcase/foundations/*": ["showcase/foundations/src/*"],
      "@showcase/*": ["showcase/*/src"]
    }
  },
  "include": ["packages/app/src", "packages/ds/src", "apps/*/src", "showcase/*/src"],
  "exclude": ["packages/ds/src/build.ts"]
}
