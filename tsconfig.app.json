{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,

    "baseUrl": ".",
    "paths": {
      "@p/ds": ["packages/ds/src/index.ts"],
      "@p/ds/foundations": ["packages/ds/src/tokens/foundations/index.ts"],
      "@p/ds/foundations/*": ["packages/ds/src/tokens/foundations/*"],
      "@p/ds/palette": ["packages/ds/src/tokens/palette/index.ts"],
      "@p/ds/palette/*": ["packages/ds/src/tokens/palette/*"],
      "@p/ds/style/preset": ["packages/ds/src/tokens/style/preset/index.ts"],
      "@p/ds/style/preset/*": ["packages/ds/src/tokens/style/preset/*"],
      "@p/ds/style/seed": ["packages/ds/src/tokens/style/seed/index.ts"],
      "@p/ds/style/seed/*": ["packages/ds/src/tokens/style/seed/*"],
      "@p/ds/style/shell": ["packages/ds/src/tokens/style/shell/index.ts"],
      "@p/ds/style/states": ["packages/ds/src/tokens/style/states/index.ts"],
      "@p/ds/core/*": ["packages/ds/src/headless/*"],
      "@p/ds/layout": ["packages/ds/src/headless/layout/index.ts"],
      "@p/ds/layout/recipes": ["packages/ds/src/ui/recipes/index.ts"],
      "@p/ds/layout/recipes/*": ["packages/ds/src/ui/recipes/*"],
      "@p/ds/parts": ["packages/ds/src/ui/parts/index.ts"],
      "@p/ds/parts/*": ["packages/ds/src/ui/parts/*"],
      "@p/ds/ui/7-patterns/ContractCard": ["packages/ds/src/content/ContractCard.tsx"],
      "@p/ds/ui/7-patterns/CourseCard": ["packages/ds/src/content/CourseCard.tsx"],
      "@p/ds/ui/7-patterns/RoleCard": ["packages/ds/src/content/RoleCard.tsx"],
      "@p/ds/ui/7-patterns/ProductCard": ["packages/ds/src/content/ProductCard.tsx"],
      "@p/ds/ui/7-patterns/PostCard": ["packages/ds/src/content/PostCard.tsx"],
      "@p/ds/ui/7-patterns/FeedPost": ["packages/ds/src/content/FeedPost.tsx"],
      "@p/ds/ui/7-patterns/*": ["packages/ds/src/ui/patterns/*"],
      "@p/ds/*": ["packages/ds/src/*"],
      "@p/fs": ["packages/fs/src/index.ts"],
      "@p/fs/*": ["packages/fs/src/*"],
      "@p/devtools": ["packages/devtools/src/index.ts"],
      "@p/devtools/*": ["packages/devtools/src/*"],
      "@p/app": ["packages/app/src/main.tsx"],
      "@p/app/*": ["packages/app/src/*"],
      "@apps/*": ["apps/*/src"],
      "@showcase/*": ["showcase/*/src"]
    }
  },
  "include": ["packages/app/src", "packages/ds/src", "apps/*/src", "showcase/*/src"],
  "exclude": ["packages/ds/src/build.ts"]
}
