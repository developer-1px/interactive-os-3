#!/usr/bin/env bash
# ds pre-commit hook — 모든 ds 린트는 경고만 (커밋 차단 ❌). 빨간 줄은 후속 정리 대상으로 남긴다.
# 설치: `bash scripts/install-git-hook.sh` 1회 실행.
cd "$(git rev-parse --show-toplevel)"

run_warn () {
  local name="$1"; shift
  echo "→ $name"
  if ! "$@"; then
    echo "⚠️  $name 위반 있음 (커밋은 허용, 추후 수정)"
  fi
}

run_warn "lint:ds (hatch/classless/inline)"        node scripts/lint-ds.mjs
run_warn "lint:ds:values"                          node scripts/lint-ds-values.mjs
run_warn "lint:ds:invariants"                      node scripts/lint-ds-invariants.mjs
run_warn "lint:ds:contracts"                       node scripts/lint-ds-contracts.mjs
run_warn "lint:ds:keyboard"                        node scripts/lint-ds-keyboard.mjs
run_warn "lint:ds:serializable"                    node scripts/lint-ds-serializable.mjs
run_warn "lint:ds:css-orphans"                     node scripts/lint-ds-css-orphans.mjs

echo "✅ ds lint 경고 단계 완료"
